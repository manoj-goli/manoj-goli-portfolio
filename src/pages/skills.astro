---
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/ui/Card.astro";
import { site } from "@data/site";

const title = `Skills - ${site.name}`;
const description = "Technical skills across platform engineering, observability, AI, APIs, identity, and troubleshooting.";

const skillGroups = [
  {
    title: "Platform & Cloud",
    items: [
      "Kubernetes",
      "OpenShift",
      "Docker",
      "Podman",
      "Minikube",
      "IBM Code Engine",
      "GCP / GKE",
      "Azure VM",
      "Quay.io",
      "Kubernetes manifests",
    ],
  },
  {
    title: "Observability & Reliability",
    items: [
      "Instana",
      "Datadog",
      "Grafana",
      "Prometheus",
      "OpenTelemetry concepts",
      "KPIs, thresholds, alerting, and SLA-aware operations",
      "Distributed tracing concepts",
      "CPU, memory, heap, and OpenShift workload monitoring",
    ],
  },
  {
    title: "AI, RAG & Governance",
    items: [
      "Watsonx.ai",
      "Watsonx.governance",
      "RAG architecture",
      "Prompt engineering",
      "Third-party model governance",
      "LlamaIndex",
      "LangChain",
      "Elasticsearch / ELSER semantic search",
      "Azure OpenAI and AWS SageMaker integration",
    ],
  },
  {
    title: "Application & API Development",
    items: [
      "Python",
      "JavaScript",
      "Node.js",
      "Express.js",
      "FastAPI",
      "Flask",
      "REST APIs",
      "Pydantic",
      "React",
      "Frontend-to-backend integration",
    ],
  },
  {
    title: "Identity & Security",
    items: [
      "IBM Security Verify",
      "SAML SSO",
      "Azure Active Directory integration",
      "RBAC",
      "JWT-based authentication",
      "Secure session handling",
      "Secrets management",
      "Kubernetes secrets",
      "Synthetic data handling",
    ],
  },
  {
    title: "Delivery & Troubleshooting",
    items: [
      "CI/CD concepts",
      "Jenkins",
      "Dockerfile creation",
      "Deployment YAML authoring",
      "Release support",
      "Incident triage",
      "RCA and runbooks",
      "Layered troubleshooting",
      "Technical documentation",
      "Client playbacks and handoffs",
    ],
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          Skills
        </p>
        <h1 class="section-heading">Technical focus areas</h1>
        <p class="section-lead mt-5">
          Skills built through platform engineering, observability, AI proof-of-concept delivery,
          identity integration, application support, and client-facing technical work.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          skillGroups.map((group) => (
            <Card>
              <h2 class="text-xl font-semibold text-primary">{group.title}</h2>
              <ul class="mt-4 space-y-2 text-sm leading-6 text-text-muted">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </Card>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
