---
import BaseLayout from "@layouts/BaseLayout.astro";
import Badge from "@components/ui/Badge.astro";
import Card from "@components/ui/Card.astro";
import { getCollection } from "astro:content";
import { site } from "@data/site";

const title = `Projects - ${site.name}`;
const description = "Selected platform engineering, observability, and AI project themes.";
const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          Projects
        </p>
        <h1 class="section-heading">Selected project themes</h1>
        <p class="section-lead mt-5">
          Sanitized project writeups covering platform engineering, observability, automation,
          and practical AI proof of concept work.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          projects.map((project) => (
            <Card href={`/projects/${project.id}`} class="h-full">
              <div class="flex h-full flex-col">
                <h2 class="text-xl font-semibold leading-snug text-primary">
                  {project.data.title}
                </h2>
                <p class="mt-3 flex-1 text-sm leading-6 text-text-muted">
                  {project.data.description}
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {project.data.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </div>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
