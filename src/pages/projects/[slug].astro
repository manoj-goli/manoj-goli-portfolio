---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Badge from "@components/ui/Badge.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import { site } from "@data/site";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const title = `${project.data.title} - ${site.name}`;
const description = project.data.description;
const dateLabel = project.data.displayDate || project.data.date.toLocaleDateString("en", {
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <a href="/projects" class="text-sm font-semibold text-accent hover:text-accent-hover">
        Back to projects
      </a>

      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_320px] lg:items-start">
        <article>
          <div class="max-w-3xl">
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
              {project.data.status}
            </p>
            <h1 class="section-heading">{project.data.title}</h1>
            <p class="section-lead mt-5">{project.data.description}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {project.data.tags.map((tag) => <Badge>{tag}</Badge>)}
            </div>
          </div>

          <div class="project-content mt-12 max-w-3xl">
            <Content />
          </div>
        </article>

        <Card class="lg:sticky lg:top-24">
          <h2 class="text-xl font-semibold text-primary">Project details</h2>
          <dl class="mt-5 space-y-5">
            <div>
              <dt class="text-sm font-semibold uppercase tracking-[0.14em] text-accent">
                Date
              </dt>
              <dd class="mt-1 text-text-muted">{dateLabel}</dd>
            </div>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-[0.14em] text-accent">
                Tools used
              </dt>
              <dd class="mt-3 flex flex-wrap gap-2">
                {project.data.tools.map((tool) => <Badge>{tool}</Badge>)}
              </dd>
            </div>
          </dl>
          <Button href="/contact" variant="secondary" class="mt-6 w-full">
            Discuss similar work
          </Button>
        </Card>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-content {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.8;
  }

  .project-content :global(h2) {
    color: var(--color-primary);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    margin-top: 2rem;
  }

  .project-content :global(h2:first-child) {
    margin-top: 0;
  }

  .project-content :global(p) {
    margin-top: 0.875rem;
  }

  .project-content :global(ul) {
    margin-top: 0.875rem;
    padding-left: 1.25rem;
  }

  .project-content :global(li) {
    list-style: disc;
    margin-top: 0.375rem;
  }
</style>
