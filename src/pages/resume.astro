---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import { site } from "@data/site";

const title = `Resume - ${site.name}`;
const description = "Download Manoj Goli's resume for platform engineering and observability roles.";
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          Resume
        </p>
        <h1 class="section-heading">Resume</h1>
        <p class="section-lead mt-5">
          A concise overview of platform engineering, observability, Kubernetes, CI/CD, and
          practical AI proof of concept experience.
        </p>
      </div>

      <Card class="mt-10 max-w-2xl">
        <h2 class="text-xl font-semibold text-primary">Download the resume</h2>
        <p class="mt-3 text-text-muted">
          Use the PDF for a recruiter-friendly summary of experience, technical focus areas,
          and project work.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Button href={site.resumePath} target="_blank" rel="noopener noreferrer">
            View Resume PDF
          </Button>
          <Button href="/contact" variant="secondary">Contact Manoj</Button>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
