---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const title = `About - ${site.name}`;
const description = "Platform, observability, Kubernetes/OpenShift, AI pilot, and client-facing delivery experience.";
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          About Manoj
        </p>
        <h1 class="section-heading">Platform engineering grounded in delivery</h1>
        <p class="section-lead mt-5">
          I work across platform engineering, observability, Kubernetes/OpenShift, AI pilots, and
          client-facing technical delivery. My focus is turning unclear requirements into working
          demos, deployment-ready assets, and clear technical handoffs.
        </p>

        <div class="mt-8 space-y-6 text-text-muted">
          <p>
            I have worked with application code, APIs, containers, Kubernetes, cloud environments,
            identity integration, observability tooling, and production support. I am comfortable
            debugging across layers and explaining technical tradeoffs in plain language.
          </p>
          <p>
            Recent work includes Instana observability, Watsonx.ai RAG pilots, AI governance
            proof-of-concept work, IBM Security Verify integrations, and repeatable deployment
            assets for public-sector-aligned demos.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
