---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const title = `About - ${site.name}`;
const description = "Platform, observability, Kubernetes/OpenShift, AI pilot, and client-facing delivery experience.";
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-4xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          About Manoj
        </p>
        <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-primary md:text-4xl lg:text-5xl text-balance">
          I work where application delivery, platforms, observability, and client outcomes meet.
        </h1>
        <p class="section-lead mt-6 max-w-3xl">
          I am a platform and observability engineer with experience across Kubernetes/OpenShift ☸️,
          AI pilots, identity integration, DevOps, and production support.
        </p>

        <div class="mt-8 max-w-3xl space-y-5 text-base leading-7 text-text-muted md:text-lg">
          <p>
            My work usually sits between application code and the platform it runs on: APIs,
            containers, Kubernetes deployment assets ☸️, identity flows, dashboards 📊, and client-facing
            technical delivery.
          </p>
          <p>
            I enjoy turning unclear technical requirements into something teams can test, explain,
            and hand off 🚀.
          </p>
          <p>
            Outside of work, I enjoy storytelling, public speaking, and reading books 📚 that mix
            reflection with real-life lessons. I also like ice skating ⛸️, biking 🚴‍♂️, video games 🎮, exploring new places 🧭, trying good food 🍜,
            and turning everyday experiences into stories.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
