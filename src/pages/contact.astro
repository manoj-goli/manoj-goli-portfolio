---
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/ui/Card.astro";
import { site } from "@data/site";

const title = `Contact - ${site.name}`;
const description = "Get in touch with Manoj Goli.";

const contactLinks = [
  {
    label: "Email",
    value: site.email,
    href: `mailto:${site.email}`,
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/manoj-goli",
    href: site.socials.linkedin,
  },
  {
    label: "GitHub",
    value: "github.com/manoj-goli",
    href: site.socials.github,
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-surface">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          Contact
        </p>
        <h1 class="section-heading">Get in touch</h1>
        <p class="section-lead mt-5">
          Reach out for platform engineering, observability, Kubernetes, CI/CD, or practical AI
          proof of concept conversations.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          contactLinks.map((link) => (
            <Card href={link.href} class="h-full">
              <p class="text-sm font-semibold uppercase tracking-[0.14em] text-accent">
                {link.label}
              </p>
              <p class="mt-3 break-words text-lg font-semibold text-primary">{link.value}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
