---
import { hero } from "@data/home";
import Button from "@components/ui/Button.astro";
---

<section class="section-padding flex min-h-[80vh] items-center bg-surface pt-32 pb-20">
  <div class="container-page grid items-center gap-12 lg:grid-cols-2">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-accent">
        {hero.eyebrow}
      </p>
      <h1 class="text-4xl font-black tracking-tight text-primary md:text-5xl lg:text-6xl">
        {hero.name}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
        {hero.tagline}
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <Button href={hero.primaryCta.href}>{hero.primaryCta.label}</Button>
        <Button href={hero.secondaryCta.href} variant="secondary">
          {hero.secondaryCta.label}
        </Button>
      </div>
    </div>

    <div class="mx-auto w-full max-w-sm justify-self-center md:justify-self-end">
      <div class="relative mx-auto aspect-square max-w-[280px] overflow-hidden rounded-full border-4 border-white/20 bg-primary-light shadow-2xl md:max-w-[360px]">
        <img
          src="/images/IMG_2281.jpg"
          alt="Portrait of Manoj Goli"
          width="420"
          height="420"
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
