---
import Button from "@components/ui/Button.astro";
import { hero } from "@data/home";
---

<section class="bg-primary text-white">
  <div class="container-page grid min-h-[calc(100vh-3.5rem)] items-center gap-10 py-16 md:min-h-[620px] md:grid-cols-[1.1fr_0.9fr] md:py-20">
    <div class="max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-white/70">
        {hero.eyebrow}
      </p>
      <h1 class="text-5xl font-bold leading-tight md:text-6xl">
        {hero.name}
      </h1>
      <p class="mt-4 text-2xl font-semibold text-white md:text-3xl">
        {hero.title}
      </p>
      <p class="mt-5 max-w-xl text-lg leading-8 text-white/80">
        {hero.tagline}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href={hero.primaryCta.href}>{hero.primaryCta.label}</Button>
        <Button href={hero.secondaryCta.href} variant="secondary" class="border-white text-white hover:bg-white/10">
          {hero.secondaryCta.label}
        </Button>
      </div>
    </div>

    <div class="mx-auto w-full max-w-sm justify-self-center md:justify-self-end">
      <div class="relative mx-auto aspect-square max-w-[280px] overflow-hidden rounded-full border-4 border-white/20 bg-primary-light shadow-2xl md:max-w-[360px]">
        <img
          src="/images/IMG_2281.jpg"
          alt="Portrait of Manoj Goli"
          width="420"
          height="420"
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
