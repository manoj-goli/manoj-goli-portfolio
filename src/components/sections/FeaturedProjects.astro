---
import Badge from "@components/ui/Badge.astro";
import Card from "@components/ui/Card.astro";
import { featuredProjects } from "@data/home";
---

<section class="section-padding bg-surface-alt">
  <div class="container-page">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          Featured Work
        </p>
        <h2 class="section-heading">Selected project themes</h2>
      </div>
      <a href="/projects" class="text-sm font-semibold text-accent hover:text-accent-hover">
        View all projects
      </a>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {
        featuredProjects.map((project) => (
          <Card href={project.href} class="h-full">
            <div class="flex h-full flex-col">
              <h3 class="text-xl font-semibold leading-snug text-primary">{project.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-6 text-text-muted">{project.description}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <Badge>{tag}</Badge>
                ))}
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>
