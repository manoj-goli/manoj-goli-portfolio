---
import { Icon } from "astro-icon/components";
import Card from "@components/ui/Card.astro";
import { highlights } from "@data/home";
---

<section class="section-padding bg-white">
  <div class="container-page">
    <div class="mb-10 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
        Focus Areas
      </p>
      <h2 class="section-heading">Where I create value</h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        highlights.map((item) => (
          <Card>
            <Icon name={item.icon} class="mb-5 h-8 w-8 text-accent" aria-hidden="true" />
            <p class="text-xl font-bold leading-tight text-primary">{item.value}</p>
            <p class="mt-2 text-xs leading-relaxed text-text-muted">{item.label}</p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
