---
import Button from "@components/ui/Button.astro";
---

<section class="section-padding bg-accent text-white">
  <div class="container-page flex flex-col items-center justify-between gap-8 text-center md:flex-row md:text-left">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold leading-tight">Let's connect</h2>
      <p class="mt-3 text-white/80">
        Open to platform engineering, observability, and SRE conversations where reliability and
        practical delivery matter.
      </p>
    </div>
    <Button href="/contact" class="shrink-0">Contact Manoj</Button>
  </div>
</section>
