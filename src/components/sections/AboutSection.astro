---
import Card from "@components/ui/Card.astro";
import Button from "@components/ui/Button.astro";
---

<section class="section-padding bg-surface">
  <div class="container-page">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div class="order-2 md:order-1">
        <Card class="bg-surface-alt p-8">
          <h3 class="text-2xl font-bold text-primary">Platform Engineering</h3>
          <p class="mt-4 text-text-muted">
            Building and troubleshooting deployment-ready assets with reliability, observability, and repeatable delivery in mind.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-sm font-medium text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Kubernetes/OpenShift deployments
            </li>
            <li class="flex items-center gap-3 text-sm font-medium text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              KPI, threshold, and alerting design
            </li>
            <li class="flex items-center gap-3 text-sm font-medium text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Repeatable containerized delivery
            </li>
          </ul>
        </Card>
      </div>

      <div class="order-1 md:order-2">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-accent">
          How I work
        </p>
        <h2 class="section-heading !text-3xl md:!text-4xl">Turning technical ambiguity into working, reliable assets</h2>
        <p class="section-lead mt-5">
          I connect application code, APIs, containers, Kubernetes/OpenShift, identity, and observability to help teams validate ideas, troubleshoot blockers, and hand off repeatable technical assets.
        </p>
        <div class="mt-8">
          <Button href="/about" variant="secondary">View My Background</Button>
        </div>
      </div>
    </div>
  </div>
</section>
