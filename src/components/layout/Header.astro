---
import MobileMenu from "./MobileMenu.astro";
import { site } from "@data/site";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Experience", href: "/experience" },
  { label: "Projects", href: "/projects" },
  { label: "Skills", href: "/skills" },
  { label: "Contact", href: "/contact" },
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-white md:bg-white/80 md:backdrop-blur-md">
  <div class="container-page flex h-14 items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight text-primary">
      {site.name}
    </a>

    <nav class="hidden md:flex md:items-center md:gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-text-muted transition-colors hover:text-accent"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="/resume"
        class="hidden rounded-button border border-accent px-4 py-1.5 text-xs font-semibold text-accent transition-colors hover:bg-accent/5 md:inline-flex"
      >
        Resume
      </a>
      <MobileMenu />
    </div>
  </div>
</header>
