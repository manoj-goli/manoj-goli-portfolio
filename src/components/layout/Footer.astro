---
import { site } from "@data/site";
---

<footer class="bg-primary py-10 text-white">
  <div class="container-page">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div>
        <p class="text-xl font-bold">{site.name}</p>
        <p class="mt-1 text-sm text-white/60">{site.title}</p>
      </div>

      <div class="flex gap-6">
        <a
          href={site.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium hover:text-accent"
        >
          GitHub
        </a>
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium hover:text-accent"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-10 text-center md:text-left">
      <p class="text-xs text-white/40">
        &copy; {new Date().getFullYear()} {site.name}. Built with Astro & Tailwind.
      </p>
    </div>
  </div>
</footer>
