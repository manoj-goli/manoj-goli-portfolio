interface Props {
  class?: string;
  href?: string;
}

const { class: className = "", href } = Astro.props;
const classes =
  "rounded-card border border-border bg-white p-6 shadow-card transition hover:-translate-y-0.5 hover:shadow-card-hover";
---

{
  href ? (
    <a href={href} class:list={[classes, "block", className]}>
      <slot />
    </a>
  ) : (
    <div class:list={[classes, className]}>
      <slot />
    </div>
  )
}
